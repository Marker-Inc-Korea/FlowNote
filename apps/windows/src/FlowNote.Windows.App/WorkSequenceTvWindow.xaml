<Window x:Class="FlowNote.Windows.App.WorkSequenceTvWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Work Sequence TV"
        Width="1120"
        Height="720"
        MinWidth="900"
        MinHeight="560"
        Background="#111827">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="76" />
            <RowDefinition Height="*" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0">
            <Button DockPanel.Dock="Right"
                    Width="96"
                    Height="34"
                    Content="Refresh"
                    Click="RefreshButton_Click" />
            <StackPanel>
                <TextBlock x:Name="TitleTextBlock"
                           Text="Work Sequence"
                           FontSize="30"
                           FontWeight="SemiBold"
                           Foreground="#F9FAFB" />
                <TextBlock x:Name="MetaTextBlock"
                           Margin="0,6,0,0"
                           FontSize="14"
                           Foreground="#CBD5E1" />
            </StackPanel>
        </DockPanel>

        <ListView Grid.Row="1"
                  x:Name="ItemListView"
                  ItemsSource="{Binding Items}"
                  BorderThickness="0"
                  Background="#111827"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListView.ItemContainerStyle>
                <Style TargetType="{x:Type ListViewItem}">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Margin" Value="0,0,0,10" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="#1F2937"
                            BorderBrush="#374151"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="190" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding SortOrder}"
                                       FontSize="32"
                                       FontWeight="SemiBold"
                                       Foreground="#93C5FD"
                                       VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}"
                                           FontSize="24"
                                           FontWeight="SemiBold"
                                           Foreground="#F9FAFB"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding AssignedTo}"
                                           Margin="0,6,0,0"
                                           FontSize="14"
                                           Foreground="#CBD5E1" />
                            </StackPanel>
                            <Border Grid.Column="2"
                                    Height="38"
                                    CornerRadius="4"
                                    Background="#374151"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding Status}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#F9FAFB"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock Grid.Row="2"
                   x:Name="StatusTextBlock"
                   Foreground="#94A3B8"
                   FontSize="13"
                   VerticalAlignment="Bottom" />
    </Grid>
</Window>
