<Window x:Class="FlowNote.Windows.App.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FlowNote Login"
        Width="420"
        Height="300"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}">
    <Border Margin="24"
            Padding="24"
            Background="{StaticResource PanelBackgroundBrush}"
            BorderBrush="{StaticResource PanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="6">
        <StackPanel>
            <TextBlock Text="FlowNote"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource PrimaryTextBrush}" />
            <TextBlock Margin="0,6,0,22"
                       Text="Sign in to use the Windows client."
                       Foreground="{StaticResource SecondaryTextBrush}" />

            <TextBlock Text="Login ID" FontWeight="SemiBold" />
            <TextBox x:Name="LoginIdTextBox"
                     Height="32"
                     Margin="0,4,0,12"
                     Text="admin"
                     VerticalContentAlignment="Center" />

            <TextBlock Text="Password" FontWeight="SemiBold" />
            <PasswordBox x:Name="PasswordBox"
                         Height="32"
                         Margin="0,4,0,12"
                         Password="1234" />

            <TextBlock x:Name="ErrorTextBlock"
                       MinHeight="20"
                       Foreground="#B91C1C" />

            <Button Height="34"
                    Margin="0,8,0,0"
                    Content="Sign in"
                    Click="SignInButton_Click" />
        </StackPanel>
    </Border>
</Window>
