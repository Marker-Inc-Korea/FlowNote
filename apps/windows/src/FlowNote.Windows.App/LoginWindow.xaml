<Window x:Class="FlowNote.Windows.App.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FlowNote 로그인"
        Width="420"
        Height="460"
        MinHeight="460"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}">
    <Border Margin="24"
            Padding="24,24,24,26"
            Background="{StaticResource PanelBackgroundBrush}"
            BorderBrush="{StaticResource PanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="22" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="24" />
                <RowDefinition Height="18" />
                <RowDefinition Height="36" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
            <TextBlock Text="FlowNote"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource PrimaryTextBrush}" />
            <TextBlock Margin="0,6,0,22"
                       Text="현장 문서 관리 클라이언트"
                       Foreground="{StaticResource SecondaryTextBrush}" />
            </StackPanel>

            <StackPanel Grid.Row="2">
                <TextBlock Text="아이디" FontWeight="SemiBold" />
                <TextBox x:Name="LoginIdTextBox"
                         Height="34"
                         Margin="0,4,0,0"
                         Text="admin"
                         VerticalContentAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Row="4">
                <TextBlock Text="비밀번호" FontWeight="SemiBold" />
                <PasswordBox x:Name="PasswordBox"
                             Height="34"
                             Margin="0,4,0,0"
                             Password="1234"
                             VerticalContentAlignment="Center" />
            </StackPanel>

            <TextBlock x:Name="ErrorTextBlock"
                       Grid.Row="6"
                       MinHeight="20"
                       Foreground="#B91C1C" />

            <Button Height="36"
                    Grid.Row="8"
                    Content="로그인"
                    Click="SignInButton_Click" />
        </Grid>
    </Border>
</Window>
