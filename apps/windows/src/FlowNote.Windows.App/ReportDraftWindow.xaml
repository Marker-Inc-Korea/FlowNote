<Window x:Class="FlowNote.Windows.App.ReportDraftWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="보고서 초안 검토"
        Width="1040"
        Height="680"
        MinWidth="900"
        MinHeight="580"
        Background="{StaticResource WindowBackgroundBrush}">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="92" />
            <RowDefinition Height="*" />
            <RowDefinition Height="180" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelMutedBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="136" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="보고서 제목" Foreground="{StaticResource SecondaryTextBrush}" />
                    <TextBox x:Name="TitleTextBox"
                             Height="30"
                             Margin="0,4,0,0"
                             Text="현장 검토 보고서 초안"
                             VerticalContentAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Text="관리자 요약" Foreground="{StaticResource SecondaryTextBrush}" />
                    <TextBox x:Name="SummaryTextBox"
                             Height="30"
                             Margin="0,4,0,0"
                             VerticalContentAlignment="Center" />
                </StackPanel>
                <Button Grid.Column="2"
                        Height="32"
                        Margin="0,22,8,0"
                        Content="초안 생성"
                        Click="BuildDraftButton_Click" />
                <Button Grid.Column="3"
                        Height="32"
                        Margin="0,22,0,0"
                        Content="문서 저장"
                        Click="SaveDocumentButton_Click" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Margin="10,8"
                               Text="현장 코멘트 원천"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryTextBrush}" />
                    <DataGrid x:Name="FieldCommentGrid"
                              ItemsSource="{Binding FieldComments}"
                              SelectionMode="Extended"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="제목" Binding="{Binding Title}" Width="*" />
                            <DataGridTextColumn Header="등록시간" Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd HH:mm}" Width="132" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Column="2"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Margin="10,8"
                               Text="관련 문서"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryTextBrush}" />
                    <DataGrid x:Name="DocumentGrid"
                              ItemsSource="{Binding Documents}"
                              SelectionMode="Extended"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="제목" Binding="{Binding Title}" Width="*" />
                            <DataGridTextColumn Header="파일" Binding="{Binding Detail}" Width="130" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Column="4"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Margin="10,8"
                               Text="작업순서 이력"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryTextBrush}" />
                    <DataGrid x:Name="WorkHistoryGrid"
                              ItemsSource="{Binding WorkHistory}"
                              SelectionMode="Extended"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="제목" Binding="{Binding Title}" Width="*" />
                            <DataGridTextColumn Header="등록시간" Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd HH:mm}" Width="132" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Margin="0,10,0,0"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="4">
            <TextBox x:Name="DraftTextBox"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     TextWrapping="NoWrap"
                     BorderThickness="0"
                     Padding="10" />
        </Border>

        <TextBlock Grid.Row="3"
                   x:Name="StatusTextBlock"
                   Margin="2,8,0,0"
                   Foreground="{StaticResource SecondaryTextBrush}" />
    </Grid>
</Window>
