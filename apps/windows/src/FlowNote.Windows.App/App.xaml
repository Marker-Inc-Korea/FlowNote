<Application x:Class="FlowNote.Windows.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="LoginWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F3F5F8" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#D9DEE8" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#20242B" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#5F6B7A" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB" />
    </Application.Resources>
</Application>
