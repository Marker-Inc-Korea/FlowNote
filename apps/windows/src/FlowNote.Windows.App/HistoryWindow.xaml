<Window x:Class="FlowNote.Windows.App.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="이력"
        Width="920"
        Height="560"
        MinWidth="760"
        MinHeight="460"
        Background="{StaticResource WindowBackgroundBrush}">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="10" />
            <RowDefinition Height="*" />
            <RowDefinition Height="44" />
        </Grid.RowDefinitions>

        <Border Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="14">
            <StackPanel>
                <TextBlock Text="이력"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryTextBrush}" />
                <TextBlock x:Name="SummaryTextBlock"
                           Margin="0,6,0,0"
                           Foreground="{StaticResource SecondaryTextBrush}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="4">
            <DataGrid x:Name="HistoryGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="0"
                      RowHeight="42"
                      ColumnHeaderHeight="34">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="시간" Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="150" />
                    <DataGridTextColumn Header="사용자" Binding="{Binding ActorName}" Width="120" />
                    <DataGridTextColumn Header="유형" Binding="{Binding EventType}" Width="150" />
                    <DataGridTextColumn Header="대상" Binding="{Binding TargetTitle}" Width="180" />
                    <DataGridTextColumn Header="내용" Binding="{Binding Message}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom">
            <Button Width="84"
                    Height="34"
                    Margin="0,0,8,0"
                    Content="새로고침"
                    Click="RefreshButton_Click" />
            <Button Width="84"
                    Height="34"
                    Content="닫기"
                    Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>
