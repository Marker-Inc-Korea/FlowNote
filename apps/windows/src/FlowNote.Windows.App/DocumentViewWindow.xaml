<Window x:Class="FlowNote.Windows.App.DocumentViewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="문서 보기"
        Width="760"
        Height="700"
        MinWidth="640"
        MinHeight="580"
        Background="{StaticResource WindowBackgroundBrush}">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="10" />
            <RowDefinition Height="*" />
            <RowDefinition Height="10" />
            <RowDefinition Height="190" />
        </Grid.RowDefinitions>

        <Border Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="14">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right"
                            Margin="12,0,0,0">
                    <Button x:Name="DownloadCopyButton"
                            Width="112"
                            Height="30"
                            Content="복사본 저장"
                            Click="DownloadCopyButton_Click" />
                    <TextBlock x:Name="SecurityPolicyTextBlock"
                               Margin="0,6,0,0"
                               TextAlignment="Right"
                               Foreground="{StaticResource SecondaryTextBrush}" />
                </StackPanel>
                <StackPanel>
                    <TextBlock x:Name="TitleTextBlock"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryTextBrush}" />
                    <TextBlock x:Name="MetaTextBlock"
                               Margin="0,6,0,0"
                               Foreground="{StaticResource SecondaryTextBrush}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="2"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto">
                <StackPanel Margin="12">
                    <TextBlock Text="문서 내용"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryTextBrush}" />
                    <TextBox x:Name="ContentTextBox"
                             Margin="0,8,0,14"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             TextWrapping="Wrap"
                             BorderThickness="0"
                             FontFamily="Consolas"
                             FontSize="13" />
                    <wv2:WebView2 x:Name="PdfPreview"
                                  Visibility="Collapsed"
                                  Height="520"
                                  Margin="0,8,0,14" />
                    <DataGrid x:Name="SpreadsheetPreview"
                              Visibility="Collapsed"
                              Margin="0,8,0,14"
                              MinHeight="360"
                              MaxHeight="520"
                              AutoGenerateColumns="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="All"
                              GridLinesVisibility="All"
                              RowHeight="32"
                              ColumnHeaderHeight="32" />
                    <Image x:Name="ImagePreview"
                           Visibility="Collapsed"
                           Stretch="Uniform"
                           MaxHeight="320"
                           Margin="0,8,0,14" />

                    <Border BorderBrush="{StaticResource PanelBorderBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="현장 코멘트 이력"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryTextBrush}" />
                            <TextBox x:Name="CombinedCommentTextBox"
                                     Margin="0,8,0,0"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     BorderThickness="0"
                                     FontFamily="Consolas"
                                     FontSize="13" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="4"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="40" />
                </Grid.RowDefinitions>
                <TextBlock Text="현장 코멘트"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryTextBrush}" />
                <TextBox x:Name="CommentTextBox"
                         Grid.Row="1"
                         Margin="0,8,0,8"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" />
                <DockPanel Grid.Row="2"
                           Margin="0,0,0,8">
                    <Button x:Name="SelectAttachmentButton"
                            Width="110"
                            Height="28"
                            DockPanel.Dock="Left"
                            Content="파일 첨부"
                            Click="SelectAttachmentButton_Click" />
                    <Button x:Name="ClearAttachmentButton"
                            Width="80"
                            Height="28"
                            Margin="8,0,0,0"
                            DockPanel.Dock="Left"
                            Content="비우기"
                            Click="ClearAttachmentButton_Click" />
                    <TextBlock x:Name="AttachmentSummaryTextBlock"
                               Margin="10,5,0,0"
                               Text="첨부 없음"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{StaticResource SecondaryTextBrush}" />
                </DockPanel>
                <Button x:Name="SaveCommentButton"
                        Grid.Row="3"
                        Width="120"
                        Height="34"
                        HorizontalAlignment="Right"
                        Content="저장"
                        Click="SaveCommentButton_Click" />
            </Grid>
        </Border>
    </Grid>
</Window>
