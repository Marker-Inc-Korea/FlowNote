<Window x:Class="FlowNote.Windows.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FlowNote"
        Width="1200"
        Height="760"
        MinWidth="980"
        MinHeight="620"
        Background="{StaticResource WindowBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="*" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel Margin="20,0">
                <TextBlock DockPanel.Dock="Left"
                           Text="FlowNote"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryTextBrush}"
                           VerticalAlignment="Center" />
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="SignedInUserTextBlock"
                               Margin="0,0,16,0"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               VerticalAlignment="Center" />
                    <Button Width="96"
                            Height="32"
                            Margin="0,0,8,0"
                            Content="New folder"
                            Click="NewFolderButton_Click" />
                    <Button Width="120"
                            Height="32"
                            Content="Register doc"
                            Click="RegisterDocumentButton_Click" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Margin="16,14,16,8"
                               Text="Folders"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryTextBrush}" />
                    <TreeView ItemsSource="{Binding Folders}"
                              Margin="8,0,8,12"
                              BorderThickness="0">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Margin="2,4">
                                    <TextBlock Text="Folder" Margin="0,0,8,0" Foreground="{StaticResource SecondaryTextBrush}" />
                                    <TextBlock Text="{Binding Name}" />
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </DockPanel>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="42" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{StaticResource PanelBackgroundBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12,0">
                    <DockPanel>
                        <TextBox Width="360"
                                 Height="28"
                                 Text="Search by title, file name, or tag"
                                 VerticalContentAlignment="Center" />
                        <TextBlock DockPanel.Dock="Right"
                                   Text="Explorer document list"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                </Border>

                <Border Grid.Row="1"
                        Margin="0,8,0,0"
                        Background="{StaticResource PanelBackgroundBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <DataGrid ItemsSource="{Binding Documents}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0"
                              RowHeight="38">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*" />
                            <DataGridTextColumn Header="File name" Binding="{Binding FileName}" Width="180" />
                            <DataGridTextColumn Header="Type" Binding="{Binding DocumentType}" Width="90" />
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90" />
                            <DataGridTextColumn Header="Version" Binding="{Binding VersionLabel}" Width="80" />
                            <DataGridTextColumn Header="Updated by" Binding="{Binding UpdatedBy}" Width="110" />
                            <DataGridTextColumn Header="Updated at" Binding="{Binding UpdatedAt, StringFormat=yyyy-MM-dd HH:mm}" Width="150" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>

            <Border Grid.Column="4"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="16">
                <StackPanel>
                    <TextBlock Text="Document details"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryTextBrush}" />
                    <TextBlock Margin="0,10,0,18"
                               Text="Selected document status, version, change reason, and field publishing information will be shown here."
                               TextWrapping="Wrap"
                               Foreground="{StaticResource SecondaryTextBrush}" />
                    <TextBlock Text="Current scope" FontWeight="SemiBold" />
                    <TextBlock Margin="0,4,0,12" Text="Local SQLite login, folder management, and document registration basics." TextWrapping="Wrap" />
                    <TextBlock Text="Authentication" FontWeight="SemiBold" />
                    <TextBlock Margin="0,4,0,12" Text="The client opens only after a successful login." TextWrapping="Wrap" />
                    <TextBlock Text="Next scope" FontWeight="SemiBold" />
                    <TextBlock Margin="0,4,0,0" Text="Server API integration and real file upload are separate follow-up work." TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="0,1,0,0">
            <TextBlock Margin="16,0"
                       Text="{Binding StatusText}"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       VerticalAlignment="Center" />
        </Border>
    </Grid>
</Window>
