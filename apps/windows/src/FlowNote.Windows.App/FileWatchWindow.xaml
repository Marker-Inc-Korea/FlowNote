<Window x:Class="FlowNote.Windows.App.FileWatchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="파일 감시"
        Width="980"
        Height="640"
        MinWidth="820"
        MinHeight="540"
        Background="{StaticResource WindowBackgroundBrush}">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="10" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="44" />
        </Grid.RowDefinitions>

        <Border Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="감시 폴더"
                           Margin="0,0,10,0"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryTextBrush}"
                           VerticalAlignment="Center" />
                <TextBox x:Name="WatchFolderTextBox"
                         Grid.Column="1"
                         Height="30"
                         VerticalContentAlignment="Center" />
                <Button Grid.Column="2"
                        Width="84"
                        Height="32"
                        Margin="8,0,0,0"
                        Content="찾아보기"
                        Click="BrowseButton_Click" />
                <Button x:Name="StartWatchButton"
                        Grid.Column="3"
                        Width="84"
                        Height="32"
                        Margin="8,0,0,0"
                        Content="시작"
                        Click="StartWatchButton_Click" />
                <Button x:Name="StopWatchButton"
                        Grid.Column="4"
                        Width="84"
                        Height="32"
                        Margin="8,0,0,0"
                        Content="중지"
                        Click="StopWatchButton_Click" />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="4">
            <DataGrid x:Name="CandidateGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="0"
                      RowHeight="42"
                      ColumnHeaderHeight="34"
                      SelectionChanged="CandidateGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="감지시간" Binding="{Binding DetectedAt, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="150" />
                    <DataGridTextColumn Header="파일" Binding="{Binding FileName}" Width="*" />
                    <DataGridTextColumn Header="연결 문서" Binding="{Binding DocumentTitle}" Width="220" />
                    <DataGridTextColumn Header="상태" Binding="{Binding Status}" Width="100" />
                    <DataGridTextColumn Header="크기" Binding="{Binding SizeBytes}" Width="90" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="4"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="180" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="대상 문서"
                           Margin="0,0,10,0"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryTextBrush}"
                           VerticalAlignment="Center" />
                <ComboBox x:Name="DocumentComboBox"
                          Grid.Column="1"
                          Height="30"
                          DisplayMemberPath="DisplayText"
                          SelectedValuePath="DocumentId" />
                <TextBlock Grid.Column="2"
                           Text="버전"
                           Margin="12,0,8,0"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryTextBrush}"
                           VerticalAlignment="Center" />
                <TextBox x:Name="VersionLabelTextBox"
                         Grid.Column="3"
                         Height="30"
                         VerticalContentAlignment="Center" />

                <TextBlock Grid.Row="2"
                           Text="변경 사유"
                           Margin="0,0,10,0"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryTextBrush}"
                           VerticalAlignment="Center" />
                <TextBox x:Name="ChangeReasonTextBox"
                         Grid.Row="2"
                         Grid.Column="1"
                         Grid.ColumnSpan="3"
                         Height="30"
                         VerticalContentAlignment="Center" />
            </Grid>
        </Border>

        <DockPanel Grid.Row="5"
                   VerticalAlignment="Bottom">
            <TextBlock x:Name="StatusTextBlock"
                       DockPanel.Dock="Left"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       VerticalAlignment="Center" />
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Width="84"
                        Height="34"
                        Margin="0,0,8,0"
                        Content="새로고침"
                        Click="RefreshButton_Click" />
                <Button Width="84"
                        Height="34"
                        Margin="0,0,8,0"
                        Content="확정"
                        Click="ConfirmButton_Click" />
                <Button Width="84"
                        Height="34"
                        Margin="0,0,8,0"
                        Content="무시"
                        Click="IgnoreButton_Click" />
                <Button Width="84"
                        Height="34"
                        Content="닫기"
                        Click="CloseButton_Click" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
