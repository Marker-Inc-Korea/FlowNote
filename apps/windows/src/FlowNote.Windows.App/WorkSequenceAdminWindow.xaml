<Window x:Class="FlowNote.Windows.App.WorkSequenceAdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="작업순서 관리"
        Width="980"
        Height="640"
        MinWidth="860"
        MinHeight="560"
        Background="{StaticResource WindowBackgroundBrush}">
    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="4">
            <DockPanel>
                <Border DockPanel.Dock="Top"
                        Height="124"
                        Padding="12"
                        Background="{StaticResource PanelMutedBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="작업판"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}" />
                        <TextBox x:Name="BoardTitleTextBox"
                                 Height="30"
                                 Margin="0,8,0,0"
                                 VerticalContentAlignment="Center"
                                 Text="오늘 작업순서" />
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBox x:Name="LineCodeTextBox"
                                     Width="132"
                                     Height="30"
                                     VerticalContentAlignment="Center"
                                     Text="라인-A" />
                            <Button Width="110"
                                    Height="30"
                                    Margin="8,0,0,0"
                                    Content="새 작업판"
                                    Click="CreateBoardButton_Click" />
                        </StackPanel>
                    </StackPanel>
                </Border>
                <ListBox x:Name="BoardListBox"
                         ItemsSource="{Binding Boards}"
                         DisplayMemberPath="Title"
                         SelectionChanged="BoardListBox_SelectionChanged"
                         Margin="8" />
            </DockPanel>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="84" />
                <RowDefinition Height="*" />
                <RowDefinition Height="118" />
                <RowDefinition Height="28" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="12,0">
                <DockPanel>
                    <TextBlock x:Name="SelectedBoardTextBlock"
                               Text="작업판을 선택하거나 생성하세요"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               VerticalAlignment="Center" />
                    <Button DockPanel.Dock="Right"
                            Width="118"
                            Height="30"
                            Content="현황판 열기"
                            Click="OpenTvViewButton_Click" />
                </DockPanel>
            </Border>

            <Border Grid.Row="1"
                    Margin="0,8,0,0"
                    Background="{StaticResource PanelMutedBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="116" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="작업 항목"
                                   Foreground="{StaticResource SecondaryTextBrush}" />
                        <TextBox x:Name="ItemTitleTextBox"
                                 Height="30"
                                 Margin="0,4,8,0"
                                 VerticalContentAlignment="Center" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="담당자"
                                   Foreground="{StaticResource SecondaryTextBrush}" />
                        <TextBox x:Name="AssignedToTextBox"
                                 Height="30"
                                 Margin="0,4,8,0"
                                 VerticalContentAlignment="Center" />
                    </StackPanel>
                    <Button Grid.Column="2"
                            Height="32"
                            Margin="0,22,0,0"
                            Content="항목 추가"
                            Click="AddItemButton_Click" />
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Margin="0,8,0,0"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                <DataGrid x:Name="ItemGrid"
                          ItemsSource="{Binding Items}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          RowHeight="38"
                          ColumnHeaderHeight="34">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding SortOrder}" Width="52" />
                        <DataGridTextColumn Header="제목" Binding="{Binding Title}" Width="*" />
                        <DataGridTextColumn Header="상태" Binding="{Binding Status}" Width="120" />
                        <DataGridTextColumn Header="보류 사유" Binding="{Binding HoldReason}" Width="150" />
                        <DataGridTextColumn Header="담당자" Binding="{Binding AssignedTo}" Width="120" />
                        <DataGridTextColumn Header="수정시간" Binding="{Binding UpdatedAt, StringFormat=yyyy-MM-dd HH:mm}" Width="150" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Row="3"
                    Margin="0,8,0,0"
                    Background="{StaticResource PanelMutedBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="112" />
                        <ColumnDefinition Width="112" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="116" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="변경 사유"
                                   Foreground="{StaticResource SecondaryTextBrush}" />
                        <TextBox x:Name="ReasonTextBox"
                                 Height="30"
                                 Margin="0,4,8,0"
                                 VerticalContentAlignment="Center" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Height="32"
                            Margin="0,22,8,0"
                            Content="위로"
                            Click="MoveUpButton_Click" />
                    <Button Grid.Column="2"
                            Height="32"
                            Margin="0,22,8,0"
                            Content="아래로"
                            Click="MoveDownButton_Click" />
                    <ComboBox x:Name="StatusComboBox"
                              Grid.Column="3"
                              Height="32"
                              Margin="0,22,8,0"
                              SelectedIndex="0">
                        <ComboBoxItem Content="대기" Tag="WAITING" />
                        <ComboBoxItem Content="진행중" Tag="IN_PROGRESS" />
                        <ComboBoxItem Content="보류" Tag="HOLD" />
                        <ComboBoxItem Content="완료" Tag="COMPLETED" />
                    </ComboBox>
                    <Button Grid.Column="4"
                            Height="32"
                            Margin="0,22,0,0"
                            Content="상태 변경"
                            Click="SetStatusButton_Click" />
                </Grid>
            </Border>

            <TextBlock Grid.Row="4"
                       x:Name="StatusTextBlock"
                       Margin="2,6,0,0"
                       Foreground="{StaticResource SecondaryTextBrush}" />
        </Grid>
    </Grid>
</Window>
