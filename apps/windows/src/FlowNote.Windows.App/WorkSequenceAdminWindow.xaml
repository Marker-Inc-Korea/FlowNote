<Window x:Class="FlowNote.Windows.App.WorkSequenceAdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Work Sequence Admin"
        Width="980"
        Height="640"
        MinWidth="860"
        MinHeight="560"
        Background="{StaticResource WindowBackgroundBrush}">
    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="4">
            <DockPanel>
                <Border DockPanel.Dock="Top"
                        Height="124"
                        Padding="12"
                        Background="{StaticResource PanelMutedBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="Boards"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}" />
                        <TextBox x:Name="BoardTitleTextBox"
                                 Height="30"
                                 Margin="0,8,0,0"
                                 VerticalContentAlignment="Center"
                                 Text="Today work sequence" />
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBox x:Name="LineCodeTextBox"
                                     Width="132"
                                     Height="30"
                                     VerticalContentAlignment="Center"
                                     Text="line-a" />
                            <Button Width="110"
                                    Height="30"
                                    Margin="8,0,0,0"
                                    Content="New Board"
                                    Click="CreateBoardButton_Click" />
                        </StackPanel>
                    </StackPanel>
                </Border>
                <ListBox x:Name="BoardListBox"
                         ItemsSource="{Binding Boards}"
                         DisplayMemberPath="Title"
                         SelectionChanged="BoardListBox_SelectionChanged"
                         Margin="8" />
            </DockPanel>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="84" />
                <RowDefinition Height="*" />
                <RowDefinition Height="118" />
                <RowDefinition Height="28" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="12,0">
                <DockPanel>
                    <TextBlock x:Name="SelectedBoardTextBlock"
                               Text="Select or create a board"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               VerticalAlignment="Center" />
                    <Button DockPanel.Dock="Right"
                            Width="118"
                            Height="30"
                            Content="Open TV View"
                            Click="OpenTvViewButton_Click" />
                </DockPanel>
            </Border>

            <Border Grid.Row="1"
                    Margin="0,8,0,0"
                    Background="{StaticResource PanelMutedBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="116" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Item title"
                                   Foreground="{StaticResource SecondaryTextBrush}" />
                        <TextBox x:Name="ItemTitleTextBox"
                                 Height="30"
                                 Margin="0,4,8,0"
                                 VerticalContentAlignment="Center" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Assigned"
                                   Foreground="{StaticResource SecondaryTextBrush}" />
                        <TextBox x:Name="AssignedToTextBox"
                                 Height="30"
                                 Margin="0,4,8,0"
                                 VerticalContentAlignment="Center" />
                    </StackPanel>
                    <Button Grid.Column="2"
                            Height="32"
                            Margin="0,22,0,0"
                            Content="Add Item"
                            Click="AddItemButton_Click" />
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Margin="0,8,0,0"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                <DataGrid x:Name="ItemGrid"
                          ItemsSource="{Binding Items}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          RowHeight="38"
                          ColumnHeaderHeight="34">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding SortOrder}" Width="52" />
                        <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120" />
                        <DataGridTextColumn Header="Hold Reason" Binding="{Binding HoldReason}" Width="150" />
                        <DataGridTextColumn Header="Assigned" Binding="{Binding AssignedTo}" Width="120" />
                        <DataGridTextColumn Header="Updated" Binding="{Binding UpdatedAt, StringFormat=yyyy-MM-dd HH:mm}" Width="150" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Row="3"
                    Margin="0,8,0,0"
                    Background="{StaticResource PanelMutedBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="112" />
                        <ColumnDefinition Width="112" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="116" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Change reason"
                                   Foreground="{StaticResource SecondaryTextBrush}" />
                        <TextBox x:Name="ReasonTextBox"
                                 Height="30"
                                 Margin="0,4,8,0"
                                 VerticalContentAlignment="Center" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Height="32"
                            Margin="0,22,8,0"
                            Content="Move Up"
                            Click="MoveUpButton_Click" />
                    <Button Grid.Column="2"
                            Height="32"
                            Margin="0,22,8,0"
                            Content="Move Down"
                            Click="MoveDownButton_Click" />
                    <ComboBox x:Name="StatusComboBox"
                              Grid.Column="3"
                              Height="32"
                              Margin="0,22,8,0"
                              SelectedIndex="0">
                        <ComboBoxItem Content="WAITING" />
                        <ComboBoxItem Content="IN_PROGRESS" />
                        <ComboBoxItem Content="HOLD" />
                        <ComboBoxItem Content="COMPLETED" />
                    </ComboBox>
                    <Button Grid.Column="4"
                            Height="32"
                            Margin="0,22,0,0"
                            Content="Set Status"
                            Click="SetStatusButton_Click" />
                </Grid>
            </Border>

            <TextBlock Grid.Row="4"
                       x:Name="StatusTextBlock"
                       Margin="2,6,0,0"
                       Foreground="{StaticResource SecondaryTextBrush}" />
        </Grid>
    </Grid>
</Window>
