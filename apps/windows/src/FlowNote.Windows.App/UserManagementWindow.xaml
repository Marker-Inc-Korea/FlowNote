<Window x:Class="FlowNote.Windows.App.UserManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="사용자 관리"
        Width="920"
        Height="560"
        MinWidth="780"
        MinHeight="480"
        Background="{StaticResource WindowBackgroundBrush}">
    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="36" />
        </Grid.RowDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="4">
            <DockPanel>
                <Border DockPanel.Dock="Top"
                        Height="48"
                        Padding="14,0"
                        Background="{StaticResource PanelMutedBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="0,0,0,1">
                    <DockPanel>
                        <TextBlock Text="사용자 목록"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   VerticalAlignment="Center" />
                        <Button DockPanel.Dock="Right"
                                Width="88"
                                Height="30"
                                Content="새로고침"
                                Click="RefreshButton_Click" />
                    </DockPanel>
                </Border>
                <DataGrid x:Name="UserGrid"
                          ItemsSource="{Binding Users}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0"
                          RowHeight="38"
                          ColumnHeaderHeight="34"
                          SelectionChanged="UserGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="로그인 ID" Binding="{Binding LoginId}" Width="120" />
                        <DataGridTextColumn Header="사용자 이름" Binding="{Binding DisplayName}" Width="*" />
                        <DataGridTextColumn Header="역할" Binding="{Binding RoleLabel}" Width="130" />
                        <DataGridTextColumn Header="상태" Binding="{Binding StatusLabel}" Width="90" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <Border Grid.Column="2"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="14">
            <StackPanel>
                <TextBlock Text="사용자 정보"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryTextBrush}" />
                <TextBlock Text="사용자 ID"
                           Margin="0,14,0,4"
                           Foreground="{StaticResource SecondaryTextBrush}" />
                <TextBox x:Name="UserIdTextBox"
                         Height="30"
                         IsReadOnly="True"
                         VerticalContentAlignment="Center" />
                <TextBlock Text="로그인 ID"
                           Margin="0,10,0,4"
                           Foreground="{StaticResource SecondaryTextBrush}" />
                <TextBox x:Name="LoginIdTextBox"
                         Height="30"
                         IsReadOnly="True"
                         VerticalContentAlignment="Center" />
                <TextBlock Text="사용자 이름"
                           Margin="0,10,0,4"
                           Foreground="{StaticResource SecondaryTextBrush}" />
                <TextBox x:Name="DisplayNameTextBox"
                         Height="30"
                         VerticalContentAlignment="Center" />
                <TextBlock Text="역할"
                           Margin="0,10,0,4"
                           Foreground="{StaticResource SecondaryTextBrush}" />
                <TextBox x:Name="RoleTextBox"
                         Height="30"
                         IsReadOnly="True"
                         VerticalContentAlignment="Center" />
                <TextBlock Text="새 비밀번호"
                           Margin="0,14,0,4"
                           Foreground="{StaticResource SecondaryTextBrush}" />
                <PasswordBox x:Name="NewPasswordBox"
                             Height="30"
                             VerticalContentAlignment="Center" />
                <TextBlock Text="새 비밀번호 확인"
                           Margin="0,10,0,4"
                           Foreground="{StaticResource SecondaryTextBrush}" />
                <PasswordBox x:Name="ConfirmPasswordBox"
                             Height="30"
                             VerticalContentAlignment="Center" />
                <TextBlock Text="비밀번호를 변경하지 않으려면 비워 두세요."
                           Margin="0,8,0,0"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource SecondaryTextBrush}" />
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,18,0,0">
                    <Button Width="88"
                            Height="34"
                            Margin="0,0,8,0"
                            Content="초기화"
                            Click="ClearPasswordButton_Click" />
                    <Button Width="104"
                            Height="34"
                            Content="저장"
                            Click="SaveButton_Click" />
                </StackPanel>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="1"
                   Grid.ColumnSpan="3"
                   x:Name="StatusTextBlock"
                   Margin="2,8,0,0"
                   Foreground="{StaticResource SecondaryTextBrush}" />
    </Grid>
</Window>
